---
layout: base.liquid
---

<div class="home-layout">
  <div class="home-content">{{ content }}</div>
  <aside class="sidebar">
    <section class="latest-news">
      <h2>Latest News</h2>
{% assign sorted_posts = collections.post | reverse %}
{% for post in sorted_posts limit:4 %}
      <article>
        <header>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        </header>
      </article>
{% endfor %}
    </section>
  </aside>
</div>
